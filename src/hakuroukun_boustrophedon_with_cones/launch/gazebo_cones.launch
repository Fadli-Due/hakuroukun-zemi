<launch>
    <arg name="x" default="0.0"/>
    <arg name="y" default="0.0"/>
    <arg name="z" default="0.1"/>
    <arg name="yaw" default="0.0"/>

    <include file="$(find gazebo_ros)/launch/empty_world.launch">
        <arg name="world_name" value="$(find hakuroukun_boustrophedon_with_cones)/worlds/30x30area.world"/>
        <arg name="paused" value="false"/>
        <arg name="use_sim_time" value="true"/>
        <arg name="gui" value="true"/>
        <arg name="headless" value="false"/>
        <arg name="debug" value="false"/>
    </include>

   <param name="robot_description" command="$(find xacro)/xacro --inorder $(find hakuroukun_description)/urdf/hakuroukun.urdf.xacro" />
   <node pkg="gazebo_ros" type="spawn_model" name="spawn_urdf"
         args="-urdf -model hakuroukun -x $(arg x) -y $(arg y) -z $(arg z) -Y $(arg yaw) -param robot_description"/>
         
    <rosparam command="load" file="$(find hakuroukun_description)/config/ros_controllers.yaml" />
    <node name="gazebo_controller_spawner" pkg="controller_manager" type="spawner"
        args="joint_state_controller hakuroukun_steering_controller"/>

    <node pkg="robot_state_publisher" type="robot_state_publisher"  name="robot_state_publisher" output="screen"/>

</launch>